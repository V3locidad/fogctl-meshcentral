<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>FOG Control</title>
<style>
  html, body { height: 100%; margin: 0; }
  body { font-family: Segoe UI, Arial, sans-serif; font-size: 13px; padding: 10px; color: #222; box-sizing: border-box; }
  h2 { margin: 0 0 10px 0; font-size: 16px; }
  .bar { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; padding: 8px; background: #f4f4f4; border: 1px solid #ddd; border-radius: 4px; margin-bottom: 8px; }
  .bar input[type=text], .bar select { padding: 3px 6px; border: 1px solid #bbb; border-radius: 3px; font-size: 13px; }
  button { padding: 5px 10px; border: 1px solid #888; background: #fff; border-radius: 3px; cursor: pointer; font-size: 13px; }
  button.primary { background: #2c7be5; color: white; border-color: #2c7be5; }
  button:disabled { opacity: 0.5; cursor: not-allowed; }
  /* Columns get an explicit pixel height computed at runtime from window.innerHeight.
     We can't rely on flex/100% here: MeshCentral's plugin iframe is sized to fit content,
     so percentages collapse to 0 and the lists just keep growing past the viewport. */
  .cols { display: flex; gap: 10px; }
  .col { flex: 1; border: 1px solid #ddd; border-radius: 4px; display: flex; flex-direction: column; min-height: 0; overflow: hidden; height: 600px; }
  .col h3 { margin: 0; padding: 8px; background: #eee; border-bottom: 1px solid #ddd; font-size: 13px; flex: 0 0 auto; }
  .col .search { flex: 0 0 auto; }
  .col > div[id$="List"] { flex: 1 1 auto; overflow: auto; min-height: 0; }
  .col .search { padding: 6px 8px; border-bottom: 1px solid #eee; }
  .col .search input { width: 100%; box-sizing: border-box; padding: 3px 6px; border: 1px solid #bbb; border-radius: 3px; }
  .row { padding: 4px 8px; border-bottom: 1px solid #f0f0f0; cursor: pointer; display: flex; align-items: center; gap: 6px; }
  .row:hover { background: #f8f8ff; }
  .row .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .dot.on { background: #2ecc71; }
  .dot.off { background: #e74c3c; }
  .row .fog-status { font-size: 11px; margin-left: auto; padding: 1px 6px; border-radius: 10px; }
  .fog-status.match { background: #d4edda; color: #155724; }
  .fog-status.miss  { background: #f8d7da; color: #721c24; }
  .fog-status.pend  { background: #fff3cd; color: #856404; }
  .fog-status.ok    { background: #d1ecf1; color: #0c5460; }
  .fog-status.bad   { background: #f8d7da; color: #721c24; }
  .fog-status.none  { background: #e2e3e5; color: #383d41; }
  #logs { margin-top: 10px; background: #111; color: #ddd; font-family: Menlo, Consolas, monospace; font-size: 12px; padding: 8px; border-radius: 4px; height: 220px; min-height: 120px; overflow: auto; white-space: pre-wrap; display: none; resize: vertical; flex: 0 0 auto; }
  #progress { font-weight: 600; }
  .pill { display: inline-block; padding: 1px 8px; border-radius: 10px; background: #eee; font-size: 11px; margin-left: 6px; }
</style>
</head>
<body>
<h2>FOG Control <span id="cfgState" class="pill">checking…</span></h2>

<div class="bar">
  <strong>Action:</strong>
  <select id="actionSel">
    <option value="deploy">Deploy image</option>
    <option value="capture">Capture image</option>
    <option value="snapin">Run snapin</option>
  </select>
  <span id="imageWrap" style="display:none">
    Image: <select id="imageSel"><option value="">Default (per host)</option></select>
  </span>
  <span id="snapinWrap" style="display:none">
    Snapin: <select id="snapinSel"><option>loading…</option></select>
  </span>
  <button id="lookupBtn" title="Force re-resolve">Refresh FOG hosts</button>
  <label style="margin-left:8px" title="Send a Wake-on-LAN magic packet before the task — useful for offline hosts"><input type="checkbox" id="optWol"> WoL</label>
  <label title="Shut down the host after the task completes"><input type="checkbox" id="optShutdown"> Shutdown after</label>
  <label style="margin-left:8px"><input type="checkbox" id="scheduleOn"> Schedule</label>
  <input type="datetime-local" id="scheduleAt" disabled style="opacity:0.5">
  <button id="runBtn" class="primary">Run on selected</button>
  <span id="progress"></span>
  <span style="margin-left:auto">
    <button id="logsBtn">Logs</button>
  </span>
</div>

<div class="cols">
  <div class="col">
    <h3>Groups</h3>
    <div class="search"><input id="groupSearch" placeholder="Filter groups…"></div>
    <div id="groupList"></div>
  </div>
  <div class="col">
    <h3>Computers <span id="countLabel" class="pill"></span></h3>
    <div class="search"><input id="nodeSearch" placeholder="Filter computers…"></div>
    <div id="nodeList"></div>
  </div>
</div>

<div id="logs"></div>

<script>
(function () {
  var W = window;
  var P = (W.parent && W.parent !== W) ? W.parent : W;

  var state = {
    groups: [],
    nodes: [],
    selectedGroup: null,
    checkedNodes: {},   // nodeid -> true
    fogMap: {},         // nodeid -> { hostId, name, image } or null
    snapins: [],
    images: [],
    taskMap: {}  // hostID -> { type, label, percent, state }

  };

  function $(id) { return document.getElementById(id); }
  function log(msg) {
    var el = $('logs');
    var t = new Date().toLocaleTimeString();
    el.textContent += '[' + t + '] ' + msg + '\n';
    el.scrollTop = el.scrollHeight;
  }
  function showLogs(v) { $('logs').style.display = v ? 'block' : 'none'; }

  // ---- access the MeshCentral nodes/meshes datastructure in the parent frame ----
  function getMeshes() {
    try { return P.meshes || P.window.meshes || {}; } catch (e) { return {}; }
  }
  function getNodes() {
    try { return P.nodes || P.window.nodes || {}; } catch (e) { return {}; }
  }

  function isWindows(node) {
    // MeshCentral agent ids for Windows: 1, 2, 3, 4, 13 (consoles + service variants)
    var winIds = [1, 2, 3, 4, 13];
    return node && node.agent && winIds.indexOf(node.agent.id) !== -1;
  }

  function getNodeMac(node) {
    if (!node) return '';
    if (node.intelamt && node.intelamt.mac) return node.intelamt.mac;
    if (node.netif2) {
      var k;
      for (k in node.netif2) {
        var ifs = node.netif2[k];
        if (Array.isArray(ifs)) {
          for (var i = 0; i < ifs.length; i++) {
            if (ifs[i].mac && ifs[i].mac !== '00:00:00:00:00:00') return ifs[i].mac;
          }
        }
      }
    }
    if (node.mac) return node.mac;
    return '';
  }

  function loadFromMesh() {
    var meshes = getMeshes();
    var nodes = getNodes();
    var gList = [];
    var nList = [];
    var meshId;
    for (meshId in meshes) {
      var m = meshes[meshId];
      if (!m) continue;
      gList.push({ id: meshId, name: m.name || meshId });
    }
    var nid;
    for (nid in nodes) {
      var n = nodes[nid];
      if (!n) continue;
      if (!isWindows(n)) continue;
      // Some MeshCentral builds key `nodes` by short numeric ids and store the
      // canonical "node//..." identifier in `_id`. runcommands needs the long form.
      var fullId = n._id || nid;
      nList.push({
        id: fullId,
        name: n.name || fullId,
        meshid: n.meshid,
        online: !!(n.conn & 1),
        mac: getNodeMac(n)
      });
    }
    gList.sort(function (a, b) { return a.name.localeCompare(b.name); });
    nList.sort(function (a, b) { return a.name.localeCompare(b.name); });
    state.groups = gList;
    state.nodes = nList;
  }

  function renderGroups() {
    var filter = $('groupSearch').value.toLowerCase();
    var html = '';
    html += '<div class="row" data-gid="__all__"><b>All Windows computers</b><span class="pill">' + state.nodes.length + '</span></div>';
    state.groups.forEach(function (g) {
      if (filter && g.name.toLowerCase().indexOf(filter) === -1) return;
      var count = state.nodes.filter(function (n) { return n.meshid === g.id; }).length;
      if (!count) return;
      var sel = (state.selectedGroup === g.id) ? ' style="background:#eef6ff"' : '';
      html += '<div class="row" data-gid="' + g.id + '"' + sel + '>' + escapeHtml(g.name) + '<span class="pill">' + count + '</span></div>';
    });
    $('groupList').innerHTML = html;
    [].slice.call($('groupList').querySelectorAll('.row')).forEach(function (el) {
      el.onclick = function () {
        var gid = el.getAttribute('data-gid');
        state.selectedGroup = (gid === '__all__') ? null : gid;
        renderGroups();
        renderNodes();
        autoResolveSoon();
      };
    });
  }

  function visibleNodes() {
    var filter = $('nodeSearch').value.toLowerCase();
    return state.nodes.filter(function (n) {
      if (state.selectedGroup && n.meshid !== state.selectedGroup) return false;
      if (filter && n.name.toLowerCase().indexOf(filter) === -1) return false;
      return true;
    });
  }

  function renderNodes() {
    var arr = visibleNodes();
    $('countLabel').textContent = arr.length;
    var html = '<div class="row" style="background:#fafafa"><input type="checkbox" id="checkAll"> <b>Select all visible</b></div>';
    arr.forEach(function (n) {
      var ck = state.checkedNodes[n.id] ? ' checked' : '';
      var fog = state.fogMap[n.id];
      var status = '';
      if (fog === undefined) status = '<span class="fog-status none">…</span>';
      else if (fog === null) status = '<span class="fog-status miss">no FOG host</span>';
      else status = '<span class="fog-status match">FOG #' + fog.id + (fog.image ? ' • ' + escapeHtml(fog.image) : '') + '</span>';
      var task = state.taskMap[n.id];
      var taskBadge = '';
      if (task) {
        var pct = (task.percent != null) ? (' ' + task.percent + '%') : '';
        taskBadge = '<span class="fog-status pend">' + escapeHtml(task.label + pct) + '</span>';
      }
      html += '<div class="row" data-nid="' + n.id + '">'
            + '<input type="checkbox" data-nid="' + n.id + '"' + ck + '>'
            + '<span class="dot ' + (n.online ? 'on' : 'off') + '"></span>'
            + escapeHtml(n.name)
            + status
            + taskBadge
            + '</div>';
    });
    $('nodeList').innerHTML = html;
    [].slice.call($('nodeList').querySelectorAll('input[type=checkbox][data-nid]')).forEach(function (cb) {
      cb.onclick = function (ev) {
        ev.stopPropagation();
        var nid = cb.getAttribute('data-nid');
        if (cb.checked) state.checkedNodes[nid] = true;
        else delete state.checkedNodes[nid];
      };
    });
    var ca = $('checkAll');
    if (ca) ca.onclick = function () {
      var ck = ca.checked;
      arr.forEach(function (n) {
        if (ck) state.checkedNodes[n.id] = true;
        else delete state.checkedNodes[n.id];
      });
      renderNodes();
    };
  }

  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function api(action, params) {
    var qs = 'action=' + encodeURIComponent(action);
    if (params) {
      Object.keys(params).forEach(function (k) {
        qs += '&' + encodeURIComponent(k) + '=' + encodeURIComponent(params[k]);
      });
    }
    return fetch('/pluginadmin.ashx?pin=fogctl&' + qs, { credentials: 'include' })
      .then(function (r) { return r.json(); });
  }

  function selectedNodeIds() {
    return Object.keys(state.checkedNodes);
  }

  // Resolve a specific list of nodes against FOG (default: visible nodes not yet
  // resolved). `force=true` re-resolves everything and refreshes the FOG host
  // cache on the server side.
  //
  // We batch in chunks of ~50 items because each entry encodes a full
  // "node//<hash>" identifier — past a couple hundred nodes the URL crosses
  // typical 8 KB limits and the request is silently rejected by the proxy.
  function resolveNodes(nodeList, force) {
    var items = [];
    nodeList.forEach(function (n) {
      if (!force && state.fogMap[n.id] !== undefined) return;
      items.push(encodeURIComponent(n.id) + '|' + encodeURIComponent(n.mac || '') + '|' + encodeURIComponent(n.name || ''));
    });
    if (!items.length) return Promise.resolve();
    var total = items.length;
    log('Resolving ' + total + ' node(s) against FOG…');

    var chunks = [];
    for (var i = 0; i < items.length; i += 50) chunks.push(items.slice(i, i + 50));

    var matched = 0;
    var failed = 0;
    var first = true;

    function runChunk(chunk) {
      var params = { items: chunk.join(',') };
      if (force && first) { params.refresh = '1'; first = false; }
      return api('lookupBulk', params).then(function (r) {
        Object.keys(r).forEach(function (nid) {
          state.fogMap[nid] = r[nid];
          if (r[nid]) matched++;
        });
        renderNodes();
      }).catch(function (e) {
        failed += chunk.length;
        log('lookup chunk failed: ' + (e && e.message ? e.message : e));
      });
    }

    return chunks.reduce(function (p, c) { return p.then(function () { return runChunk(c); }); }, Promise.resolve())
      .then(function () {
        log('FOG: ' + matched + '/' + total + ' matched' + (failed ? ' (' + failed + ' failed)' : '') + '.');
      });
  }

  function lookupSelected() {
    return resolveNodes(visibleNodes(), true);
  }

  // Kick off auto-resolution for the currently visible nodes. Debounced to avoid
  // calls during quick group switching.
  var resolveTimer = null;
  function autoResolveSoon() {
    if (resolveTimer) clearTimeout(resolveTimer);
    resolveTimer = setTimeout(function () { resolveNodes(visibleNodes(), false); }, 250);
  }

  // Poll FOG for active tasks. We build a map: nodeId -> task info, by reverse-
  // mapping FOG host id -> nodeId via the fogMap we already built.
  function pollActiveTasks() {
    api('activeTasks').then(function (r) {
      var byFogHost = (r && r.byHost) || {};
      var fogToNode = {};
      Object.keys(state.fogMap).forEach(function (nid) {
        var f = state.fogMap[nid];
        if (f && f.id) fogToNode[f.id] = nid;
      });
      var newMap = {};
      Object.keys(byFogHost).forEach(function (hid) {
        var nid = fogToNode[hid];
        if (nid) newMap[nid] = byFogHost[hid];
      });
      // Only re-render if anything actually changed.
      if (JSON.stringify(newMap) !== JSON.stringify(state.taskMap)) {
        state.taskMap = newMap;
        renderNodes();
      }
    }).catch(function () { /* silent */ });
  }

  function loadImages() {
    return api('imageList').then(function (r) {
      state.images = r.images || [];
      var sel = $('imageSel');
      // Preserve the "Default (per host)" entry.
      sel.innerHTML = '<option value="">Default (per host)</option>';
      state.images.forEach(function (im) {
        var o = document.createElement('option');
        o.value = im.id;
        o.textContent = im.name + (im.os ? ' (' + im.os + ')' : '');
        sel.appendChild(o);
      });
    }).catch(function (e) { log('imageList failed: ' + e.message); });
  }

  function loadSnapins() {
    return api('snapinList').then(function (r) {
      state.snapins = r.snapins || [];
      var sel = $('snapinSel');
      sel.innerHTML = '';
      if (!state.snapins.length) {
        sel.innerHTML = '<option value="">(no snapin)</option>';
        return;
      }
      state.snapins.forEach(function (s) {
        var o = document.createElement('option');
        o.value = s.id;
        o.textContent = s.name;
        sel.appendChild(o);
      });
    }).catch(function (e) { log('snapinList failed: ' + e.message); });
  }

  function runAction() {
    var action = $('actionSel').value;
    var ids = selectedNodeIds();
    if (!ids.length) { alert('No computer selected.'); return; }

    // Make sure we know the FOG host id for each selected node.
    var missing = ids.filter(function (id) { return state.fogMap[id] === undefined; });
    var p = missing.length ? lookupSelected() : Promise.resolve();

    p.then(function () {
      var hostIds = [];
      var skipped = 0;
      ids.forEach(function (id) {
        var f = state.fogMap[id];
        if (f && f.id) hostIds.push(f.id);
        else skipped++;
      });
      if (!hostIds.length) {
        alert('None of the selected computers are known to FOG.');
        return;
      }
      var flags = [];
      if ($('optWol').checked) flags.push('WoL');
      if ($('optShutdown').checked) flags.push('shutdown after');
      var when = $('scheduleOn').checked ? (' SCHEDULED for ' + $('scheduleAt').value.replace('T', ' ')) : '';
      var msg = action.toUpperCase() + ' on ' + hostIds.length + ' FOG host(s)'
              + (skipped ? ' (' + skipped + ' skipped, unknown to FOG)' : '')
              + when
              + (flags.length ? ' [' + flags.join(', ') + ']' : '');
      if (!confirm(msg + '. Continue?')) return;

      $('progress').textContent = '0/' + hostIds.length;
      log(msg);

      var apiAction, extra = {};
      if (action === 'deploy') {
        apiAction = 'deploy';
        var imgId = $('imageSel').value;
        if (imgId) extra.imageId = imgId;
      } else if (action === 'capture') {
        apiAction = 'capture';
      } else if (action === 'snapin') {
        apiAction = 'snapinRun';
        var sid = $('snapinSel').value;
        if (!sid) { alert('Pick a snapin first.'); return; }
        extra.snapinId = sid;
      }

      // Scheduled run? The datetime-local field gives us "YYYY-MM-DDTHH:MM" in
      // the user's local timezone — FOG schedules in server-local time so this
      // assumes the MeshCentral admin and the FOG server share a clock.
      if ($('scheduleOn').checked) {
        var ts = $('scheduleAt').value;
        if (!ts) { alert('Pick a date/time.'); return; }
        var when = new Date(ts);
        if (isNaN(when.getTime())) { alert('Invalid date/time.'); return; }
        if (when.getTime() < Date.now() + 30000) { alert('Pick a date in the future.'); return; }
        extra.scheduledFor = ts.replace('T', ' ');
      }

      // Per-task flags
      if ($('optWol').checked) extra.wol = '1';
      if ($('optShutdown').checked) extra.shutdown = '1';

      extra.hostIds = hostIds.join(',');
      api(apiAction, extra).then(function (r) {
        if (r && r.results) {
          var ok = 0, ko = 0, errs = [];
          Object.keys(r.results).forEach(function (hid) {
            if (r.results[hid].ok) ok++;
            else { ko++; errs.push(hid + ': ' + r.results[hid].error); }
          });
          $('progress').textContent = ok + '/' + hostIds.length + (ko ? ' (' + ko + ' failed)' : '');
          log('Done. ' + ok + ' ok, ' + ko + ' failed.');
          errs.slice(0, 10).forEach(function (e) { log('  ' + e); });
        } else if (r && r.error) {
          log('Error: ' + r.error);
          $('progress').textContent = 'error';
        }
      }).catch(function (e) {
        log('Request failed: ' + e.message);
      });
    });
  }

  // Resize columns to fill whatever vertical space is available in the *parent*
  // window. MeshCentral's plugin iframe is auto-sized to content, so percent
  // heights and flex:1 don't work — we have to measure the host page and push
  // the column to a concrete pixel height.
  function resizeCols() {
    var h;
    try { h = (W.parent && W.parent.innerHeight) ? W.parent.innerHeight : W.innerHeight; }
    catch (e) { h = W.innerHeight; }
    var cols = document.querySelector('.cols');
    if (!cols) return;
    var top = cols.getBoundingClientRect().top;
    var logsEl = $('logs');
    var logsReserve = (logsEl.style.display === 'none') ? 20 : (logsEl.offsetHeight + 30);
    var avail = h - top - logsReserve - 40;
    if (avail < 240) avail = 240;
    var list = document.querySelectorAll('.col');
    for (var i = 0; i < list.length; i++) list[i].style.height = avail + 'px';
  }

  function init() {
    loadFromMesh();
    renderGroups();
    renderNodes();
    resizeCols();
    window.addEventListener('resize', resizeCols);
    try { W.parent.addEventListener('resize', resizeCols); } catch (e) {}
    setInterval(resizeCols, 1500);

    $('groupSearch').oninput = renderGroups;
    $('nodeSearch').oninput = renderNodes;
    $('lookupBtn').onclick = function () { showLogs(true); lookupSelected(); };
    $('runBtn').onclick = runAction;
    $('logsBtn').onclick = function () { showLogs($('logs').style.display === 'none'); resizeCols(); };
    $('actionSel').onchange = function () {
      var a = $('actionSel').value;
      $('snapinWrap').style.display = (a === 'snapin') ? '' : 'none';
      $('imageWrap').style.display  = (a === 'deploy') ? '' : 'none';
    };
    // Trigger once so the initial Deploy selection shows its image dropdown.
    $('actionSel').onchange();

    // Schedule wiring: when the checkbox is on, enable the datetime input and
    // relabel the Run button. Default datetime is now + 1h, rounded to the next
    // 15 minutes — typical for "schedule for tonight" workflows.
    function updateScheduleUI() {
      var on = $('scheduleOn').checked;
      $('scheduleAt').disabled = !on;
      $('scheduleAt').style.opacity = on ? '1' : '0.5';
      $('runBtn').textContent = on ? 'Schedule on selected' : 'Run on selected';
      if (on && !$('scheduleAt').value) {
        var d = new Date(Date.now() + 3600 * 1000);
        d.setMinutes(Math.ceil(d.getMinutes() / 15) * 15, 0, 0);
        var pad = function (n) { return n < 10 ? '0' + n : '' + n; };
        $('scheduleAt').value = d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate())
                              + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
      }
    }
    $('scheduleOn').onchange = updateScheduleUI;

    // Ping the FOG server through the plugin endpoint to surface config issues early.
    api('ping').then(function (r) {
      var el = $('cfgState');
      if (r && r.ok) {
        el.textContent = 'FOG OK';
        el.style.background = '#d4edda';
        el.style.color = '#155724';
        loadImages();
        loadSnapins();
        autoResolveSoon();
        pollActiveTasks();
        setInterval(pollActiveTasks, 8000);
      } else {
        el.textContent = 'FOG: ' + (r && r.error ? r.error : 'unreachable');
        el.style.background = '#f8d7da';
        el.style.color = '#721c24';
      }
    }).catch(function () {
      var el = $('cfgState');
      el.textContent = 'plugin endpoint unreachable';
      el.style.background = '#f8d7da';
      el.style.color = '#721c24';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
</body>
</html>
